{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kermin Mod Manager",
  "version": "1.0.0",
  "identifier": "com.kerminmodmanager.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kermin Mod Manager",
        "width": 920,
        "height": 700,
        "minWidth": 720,
        "minHeight": 540,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
